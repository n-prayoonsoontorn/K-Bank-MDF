{
    "job_name": "ingest_fcd_trn_d",
    "pipeline_name": "IngestionPipeline",
    "job_info": {
        "source_name": "fcd",
        "source_system_id": "640",
        "area_name": "ingt_fcd_d",
        "raw_catalog_name": "mdp{{env}}",
        "raw_database_name": "raw_fcd",
        "raw_table_name": "fcd_trn",
        "persist_catalog_name": "mdp{{env}}",
        "persist_database_name": "persist_fcd",
        "persist_table_name": "fcd_trn"
    },
    "tasks": {
        "search_source_file_task": {
            "module_name": "GlobSearchSourcePathTask",
            "bypass_flag": "False",
            "parameters": {
                "base_directory": "/Volumes/mdp{{env}}/inbound/source_file/mdp/fcd/FCD_TRN_{{ptn_yyyy}}{{ptn_mm}}{{ptn_dd}}.txt",
                "allow_empty_flag": "False"
            }
        },
        "read_source_file_task": {
            "module_name": "DelimitedSourceFileReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "reader_options": {
                    "delimiter": "|",
                    "header": "False"
                },
                "ref_schema": {
                    "database_table": "mdp{{env}}.raw_fcd.fcd_trn",
                    "exclude_columns": [
                        "pos_dt",
                        "load_tms",
                        "src_sys_id",
                        "ptn_yyyy",
                        "ptn_mm",
                        "ptn_dd"
                    ]
                },
                "number_of_row_header": 1,
                "number_of_row_footer": 1
            }
        },
        "transform_to_raw_task": {
            "module_name": "AddColumnsDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns"
            }
        },
        "load_to_raw_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_fcd",
                "target_table_name": "fcd_trn",
                "format": "parquet"
            }
        },
        "read_raw_from_table_task": {
            "module_name": "TableSourceReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_fcd",
                "target_table_name": "fcd_trn",
                "filter_cond": "ptn_yyyy = '{{ptn_yyyy}}' AND ptn_mm = '{{ptn_mm}}' AND ptn_dd = '{{ptn_dd}}'"
            }
        },
        "transform_to_persist_task": {
            "module_name": "IngtSpecDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns",
                "ingestion_spec_path": "/Volumes/mdp{{env}}/artifact/mapping/mdp/ingest/fcd/ingest_spec_fcd_trn.json"
            }
        },
        "load_to_persist_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "persist_fcd",
                "target_table_name": "fcd_trn"
            }
        },
        "record_count_check_task": {
            "module_name": "IngestionRecordCountCheckTask",
            "bypass_flag": "False",
            "parameters": {
                "raw_database_table": "mdp{{env}}.raw_fcd.fcd_trn",
                "raw_filter_cond": "ptn_yyyy = '{{ptn_yyyy}}' AND ptn_mm = '{{ptn_mm}}' AND ptn_dd = '{{ptn_dd}}'",
                "persist_database_table": "mdp{{env}}.persist_fcd.fcd_trn",
                "persist_filter_cond": "ptn_yyyy = '{{ptn_yyyy}}' AND ptn_mm = '{{ptn_mm}}' AND ptn_dd = '{{ptn_dd}}'"
            }
        },
        "control_file_record_count_check_task": {
            "module_name": "DelimitedControlFileCheckerTask",
            "bypass_flag": "False",
            "parameters": {
                "control_file_path": "/Volumes/mdp{{env}}/inbound/source_file/mdp/fcd/FCD_TRN_{{ptn_yyyy}}{{ptn_mm}}{{ptn_dd}}.txt",
                "reader_options": {
                    "delimiter": "|",
                    "header": "False"
                },
                "ref_schema": {
                    "database_table": "mdp{{env}}.raw_fcd.fcd_trn",
                    "exclude_columns": [
                        "pos_dt",
                        "load_tms",
                        "src_sys_id",
                        "ptn_yyyy",
                        "ptn_mm",
                        "ptn_dd"
                    ]
                },
                "number_of_row_header": 1,
                "number_of_row_footer": 1,
                "record_count_index": {
                    "footer": {
                        "column_index": 1,
                        "row_index": 0
                    }
                }
            }
        },
        "audit_data_task": {
            "module_name": "DataAuditingTask",
            "bypass_flag": false,
            "parameters": {
                "config_path": "/Volumes/mdp{{env}}/artifact/config/mdp/audit/ingest/fcd/audit_config_persist_fcd_fcd_trn.json",
                "target_database_table": "mdp{{env}}.persist_fcd.fcd_trn",
                "filter_cond": "ptn_yyyy = '{{ptn_yyyy}}' AND ptn_mm = '{{ptn_mm}}' AND ptn_dd = '{{ptn_dd}}'",
                "exit_when_validation_error": true
            }
        }
    }
}