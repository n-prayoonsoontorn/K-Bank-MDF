{
    "job_name": "ingest_ks_ar_x_cst_rel_s",
    "pipeline_name": "IngestionPipeline",
    "job_info": {
        "source_name": "ks",
        "source_system_id": "None",
        "area_name": "ingt_ks_s",
        "raw_catalog_name": "mdp{{env}}",
        "raw_database_name": "raw_ks",
        "raw_table_name": "ks_ar_x_cst_rel",
        "persist_catalog_name": "mdp{{env}}",
        "persist_database_name": "persist_ks",
        "persist_table_name": "ks_ar_x_cst_rel"
    },
    "tasks": {
        "search_source_file_task": {
            "module_name": "GlobSearchSourcePathTask",
            "bypass_flag": "False",
            "parameters": {
                "base_directory": "/Volumes/mdp{{env}}/inbound/source_file/mdp/ks/KSecAcctXCust_{{ptn_yyyy}}{{ptn_mm}}{{ptn_dd}}.txt",
                "allow_empty_flag": "False"
            }
        },
        "read_source_file_task": {
            "module_name": "DelimitedSourceFileReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "reader_options": {
                    "delimiter": "|",
                    "header": "True"
                },
                "add_column_name":{
                    "position":"begin",
                    "added_columns":["rectype"]   
                },
                "number_of_row_header": 1,
                "number_of_row_footer": 1
            }
        },
        "transform_to_raw_task": {
            "module_name": "AddColumnsDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns",
                "columns_params": {
                    "ptn_yyyy": "cast('{{ptn_yyyy}}' as string)",
                    "ptn_mm": "cast('{{ptn_mm}}' as string)",
                    "ptn_dd": "cast('{{ptn_dd}}' as string)"
                }
            }
        },
        "load_to_raw_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_ks",
                "target_table_name": "ks_ar_x_cst_rel",
                "format": "parquet"
            }
        },
        "read_raw_from_table_task": {
            "module_name": "TableSourceReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_ks",
                "target_table_name": "ks_ar_x_cst_rel",
                "filter_cond": "CAST(ptn_yyyy as INT) = CAST({{ptn_yyyy}} as INT) AND CAST(ptn_mm as INT) = CAST({{ptn_mm}} as INT) AND CAST(ptn_dd as INT) = CAST({{ptn_dd}} as INT)"
            }
        },
        "transform_to_persist_task": {
            "module_name": "IngtSpecDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns",
                "ingestion_spec_path": "/Volumes/mdp{{env}}/artifact/mapping/mdp/ingest/ks/ingest_spec_ks_ar_x_cst_rel.json"
            }
        },
        "load_to_persist_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "persist_ks",
                "target_table_name": "ks_ar_x_cst_rel"
            }
        },
        "record_count_check_task": {
            "module_name": "IngestionRecordCountCheckTask",
            "bypass_flag": "False",
            "parameters": {
                "raw_database_table": "mdp{{env}}.raw_ks.ks_ar_x_cst_rel",
                "raw_filter_cond": "CAST(ptn_yyyy as INT) = CAST({{ptn_yyyy}} as INT) AND CAST(ptn_mm as INT) = CAST({{ptn_mm}} as INT) AND CAST(ptn_dd as INT) = CAST({{ptn_dd}} as INT)",
                "persist_database_table": "mdp{{env}}.persist_ks.ks_ar_x_cst_rel",
                "persist_filter_cond": "CAST(ptn_yyyy as INT) = CAST({{ptn_yyyy}} as INT) AND CAST(ptn_mm as INT) = CAST({{ptn_mm}} as INT) AND CAST(ptn_dd as INT) = CAST({{ptn_dd}} as INT)"
            }
        },
        "control_file_record_count_check_task": {
            "module_name": "DelimitedControlFileCheckerTask",
            "bypass_flag": "False",
            "parameters": {
                "control_file_path": "/Volumes/mdp{{env}}/inbound/source_file/mdp/ks/KSecAcctXCust_{{ptn_yyyy}}{{ptn_mm}}{{ptn_dd}}.txt",
                "reader_options": {
                    "delimiter": "|",
                    "header": "True"
                },
                "number_of_row_header": 1,
                "number_of_row_footer": 1,
                "record_count_index": {
                    "footer": {
                        "column_index": 1,
                        "row_index": 0
                    }
                }
            }
        },
        "audit_data_task": {
            "module_name": "DataAuditingTask",
            "bypass_flag": false,
            "parameters": {
                "config_path": "/Volumes/mdp{{env}}/artifact/config/mdp/audit/ingest/ks/audit_config_persist_ks_ks_ar_x_cst_rel.json",
                "target_database_table": "mdp{{env}}.persist_ks.ks_ar_x_cst_rel",
                "filter_cond": "CAST(ptn_yyyy as INT) = CAST({{ptn_yyyy}} as INT) AND CAST(ptn_mm as INT) = CAST({{ptn_mm}} as INT) AND CAST(ptn_dd as INT) = CAST({{ptn_dd}} as INT)",
                "exit_when_validation_error": true
            }
        }
    }
}