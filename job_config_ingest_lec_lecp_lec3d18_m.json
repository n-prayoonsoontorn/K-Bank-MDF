{
    "job_name": "ingest_lec_lecp_lec3d18_m",
    "pipeline_name": "IngestionPipeline",
    "job_info": {
        "source_name": "lec",
        "source_system_id": "72",
        "area_name": "ingest_lec_m",
        "raw_catalog_name": "mdp{{env}}",
        "raw_database_name": "raw_lec",
        "raw_table_name": "lec_lecp_lec3d18",
        "persist_catalog_name": "mdp{{env}}",
        "persist_database_name": "persist_lec",
        "persist_table_name": "lec_lecp_lec3d18"
    },
    "tasks": {
        "search_source_file_task": {
            "module_name": "GlobSearchSourcePathTask",
            "bypass_flag": "False",
            "parameters": {
                "base_directory": "/Volumes/mdp{{env}}/inbound/source_file/mdp/lec/LECP.LEC3D18.txt",
                "allow_empty_flag": "False"
            }
        },
        "read_source_file_task": {
            "module_name": "DelimitedSourceFileReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "reader_options": {
                    "delimiter": "|",
                    "header": "True"
                }
            }
        },
        "transform_to_raw_task": {
            "module_name": "AddColumnsDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns",
                "columns_params": {
                    "ptn_yyyy": "cast('{{ptn_yyyy}}' as string)",
                    "ptn_mm": "cast('{{ptn_mm}}' as string)",
                    "ptn_dd": "cast('{{ptn_dd}}' as string)"
                }
            }
        },
        "load_to_raw_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_lec",
                "target_table_name": "lec_lecp_lec3d18",
                "format": "parquet"
            }
        },
        "read_raw_from_table_task": {
            "module_name": "TableSourceReaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "raw_lec",
                "target_table_name": "lec_lecp_lec3d18",
                "filter_cond": "CAST(ptn_yyyy as INT) = CAST({{ptn_yyyy}} as INT) AND CAST(ptn_mm as INT) = CAST({{ptn_mm}} as INT) AND CAST(ptn_dd as INT) = CAST({{ptn_dd}} as INT)"
            }
        },
        "transform_to_persist_task": {
            "module_name": "IngtSpecDataTnfmTask",
            "bypass_flag": "False",
            "parameters": {
                "system_column_type": "StandardSystemColumns",
                "ingestion_spec_path": "/Volumes/mdp{{env}}/artifact/mapping/mdp/ingest/lec/ingest_spec_lec_lecp_lec3d18.json"
            }
        },
        "load_to_persist_task": {
            "module_name": "FullDumpDataLoaderTask",
            "bypass_flag": "False",
            "parameters": {
                "target_catalog_name": "mdp{{env}}",
                "target_database_name": "persist_lec",
                "target_table_name": "lec_lecp_lec3d18"
            }
        },
        "control_file_record_count_check_task": {
            "module_name": "PairedControlFileCheckerTask",
            "bypass_flag": "False",
            "parameters": {
                "control_file_path": "/Volumes/mdp{{env}}/inbound/source_file/mdp/lec/LECP.LEC3D18.ctl",
                "file_type": "delimited",
                "reader_options": {
                    "delimiter": "|",
                    "header": "True"
                },
                "record_count_column": "number_of_records"
            }
        }
    }
}